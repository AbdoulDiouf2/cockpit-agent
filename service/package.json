{
  "name": "cockpit-agent-service",
  "version": "1.1.0",
  "description": "Service Windows de synchronisation Cockpit ↔ Sage 100",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "install-service": "node src/windows-service.js install",
    "uninstall-service": "node src/windows-service.js uninstall",
    "build": "pkg src/index.js --target node18-win-x64 --output ../dist/service/cockpit-agent-service.exe"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "keytar": "^7.9.0",
    "mssql": "^10.0.4",
    "node-machine-id": "^1.1.12",
    "node-schedule": "^2.1.1",
    "node-windows": "^1.0.0-beta.8",
    "socket.io-client": "^4.8.3",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "../shared/sql/**/*.sql"
    ],
    "targets": [
      "node18-win-x64"
    ]
  }
}
